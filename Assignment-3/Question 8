//Find repeated sum of digits until a single digit remains

function repeatedSumOfDigits(num) {
    // Continue loop as long as the number has more than 1 digit
    while (num > 9) {
        // Convert to string, split into array of chars, reduce to sum of numbers
        num = String(num)
                .split('')
                .reduce((sum, digit) => sum + Number(digit), 0);
    }
    return num;
}

console.log(repeatedSumOfDigits(456)); 
// Output: 6  (4+5+6 = 15 -> 1+5 = 6)
